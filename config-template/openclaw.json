{
  "meta": {
    "lastTouchedVersion": "2026.4.11",
    "lastTouchedAt": "2026-04-11T00:00:00.000Z"
  },
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "controlUi": {
      "enabled": true,
      "allowInsecureAuth": true
    }
  },
  "auth": {
    "profiles": {
      "github-copilot:github": {
        "provider": "github-copilot",
        "mode": "token"
      }
    },
    "order": {
      "github-copilot": [
        "github-copilot:github"
      ]
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "google/gemini-3.1-flash-lite-preview"
      },
      "models": {
        "google/gemini-3.1-flash-lite-preview": {},
        "github-copilot/gpt-5-mini": {}
      }
    }
  },
  "skills": {
    "load": {
      "extraDirs": [
        "/home/appuser/.agents/skills"
      ]
    }
  },
  "cron": {
    "enabled": true,
    "store": "/home/appuser/.openclaw/cron.json"
  },
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto"
  }
}
