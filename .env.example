OPENCLAW_OPS_DIR=.
OPENCLAW_DOCKERFILE=./Dockerfile
OPENCLAW_RUNTIME_IMAGE=openclaw-runtime:local
OPENCLAW_ADDONS_DOCKERFILE=./Dockerfile.addons
OPENCLAW_ADDONS_IMAGE=openclaw-runtime-addons:local

OPENCLAW_BASE_OS_IMAGE=ubuntu:24.04
OPENCLAW_DOCKER_USER=1000:1000
OPENCLAW_GIT_URL=https://github.com/openclaw/openclaw.git
OPENCLAW_REF=main
OPENCLAW_NODE_MAJOR=22
OPENCLAW_TZ=UTC

OPENCLAW_GATEWAY_TOKEN=local-dev-token
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_CONTROL_UI_ALLOW_INSECURE_AUTH=1
OPENCLAW_DEFAULT_MODEL=github-copilot/claude-haiku-4.5
OPENCLAW_DEFAULT_PROFILE_ID=github-copilot:github
OPENCLAW_BOOTSTRAP_AGENTS_FILE=0

OPENCLAW_ADDONS_GATEWAY_PORT=18790
EXAMPLE_ADDON_INTERVAL_SEC=15

OPENCLAW_CONFIG_HOST_DIR=./build-context/local-test/quickstart/.openclaw
OPENCLAW_WORKSPACE_HOST_DIR=./build-context/local-test/quickstart/workspace
OPENCLAW_ADDONS_CONFIG_HOST_DIR=./build-context/local-test/addons-example/.openclaw
OPENCLAW_ADDONS_WORKSPACE_HOST_DIR=./build-context/local-test/addons-example/workspace
