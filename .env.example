OPENCLAW_OPS_DIR=.
OBSIDIAN_VAULT_HOST_DIR=/path/to/obsidian_vault
OPENCLAW_CONFIG_HOST_DIR=/path/to/.openclaw
OPENCLAW_OBSIDIAN_DOCKERFILE=./Dockerfile

OPENCLAW_OBSIDIAN_IMAGE=openclaw-obsidian:local
OPENCLAW_BASE_IMAGE=openclaw:v2026.2.15
OPENCLAW_BASE_IMAGE_GIT_URL=https://github.com/openclaw/openclaw.git
OPENCLAW_BASE_IMAGE_CACHE_DIR=
OPENCLAW_BASE_IMAGE_DOCKERFILE=
OPENCLAW_BASE_IMAGE_CONTEXT=
OPENCLAW_DOCKER_APT_PACKAGES=ca-certificates curl jq git ripgrep fd-find yq rsync tzdata python3 python-is-python3 python3-yaml minicom
OPENCLAW_INSTALL_OBSIDIAN_HEADLESS=1
OPENCLAW_DOCKER_USER=1000:1000
OPENCLAW_EXTERNAL_SOURCES_DIR=./build-context/external-sources
OPENCLAW_EXTERNAL_CACHE_DIR=
CUSTOM_CLAW_TOOLS_GIT_URL=https://github.com/hamanpaul/custom-claw-tools.git
CUSTOM_CLAW_TOOLS_REF=main
CUSTOM_SKILLS_GIT_URL=https://github.com/hamanpaul/custom-skills.git
CUSTOM_SKILLS_REF=main
SERIALWRAP_GIT_URL=https://github.com/hamanpaul/serialwrap.git
SERIALWRAP_REF=main

SCAN_INTERVAL_SEC=60
INIT_EXTERNALIZE_MD=1
OPENCLAW_AGENT_ID=main
OPENCLAW_DEFAULT_MODEL=github-copilot/gpt-5-mini
OPENCLAW_DEFAULT_PROFILE_ID=github-copilot:github
OPENCLAW_ENABLE_TELEGRAM_PLUGIN=1
OPENCLAW_AUTOSTART_MAINTAINER=1
OPENCLAW_AUTOSTART_GATEWAY=1
OPENCLAW_AUTOSTART_OBS=1
OPENCLAW_AUTOSTART_OPS=1
OPENCLAW_AUTOSTART_SERIALWRAP=1

# Optional auth/session settings
OPENCLAW_GATEWAY_TOKEN=local-dev-token
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_CONTROL_UI_ALLOW_INSECURE_AUTH=1
CLAUDE_AI_SESSION_KEY=
CLAUDE_WEB_SESSION_KEY=
CLAUDE_WEB_COOKIE=

# Optional sidecar/runtime paths
OBSIDIAN_HEADLESS_CONFIG_HOST_DIR=./.runtime/obsidian-headless
PICOCLAW_WORKSPACE_HOST_DIR=./.runtime/picoclaw-workspace
OPS_COMPANION_CONFIG_HOST_DIR=./.runtime/picoclaw-ops-companion
PICOCLAW_OPS_LISTEN_PORT=45450
SERIALWRAP_PROFILES_HOST_DIR=./.runtime/serialwrap/profiles
SERIALWRAP_STATE_HOST_DIR=./.runtime/serialwrap/state
SERIALWRAP_HOST_DEV_DIR=./.runtime/serialwrap/dev
SERIALWRAP_SEED_DEFAULT_PROFILES=1
SERIALWRAP_AUTOBIND_DEFAULT_TARGET=1
SERIALWRAP_BY_ID_DIR=/host-dev/serial/by-id
SERIALWRAP_BY_PATH_DIR=/host-dev/serial/by-path
